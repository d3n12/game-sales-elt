        try_cast(replace("Outside of Japan", ',', '')    as integer) * 10000 as outside_japan_sales,
        try_cast(replace("Life-to-date Global", ',', '') as integer) * 10000 as ltd_global_sales,
        source
    from source
    where
        "Game Title" is not null
        and "Game Title" not in ('-', '')
)

select * from cleaned
  );

